{
  "Carbonio": {
    "BaseUrl": "https://webmail.example.local",
    "Username": "user.name@example.local"
  },
  "Google": {
    "Calendars": [
      {
        "Id": "primary",
        "TitlePrefix": "(G)",
        "CarbonioCalendarName": "Google"
      },
      {
        "Id": "work",
        "TitlePrefix": "(W)",
        "CarbonioCalendarName": "Work"
      }
    ]
  },
  "Sync": {
    "Direction": "GoogleToCarbonio",
    "PastDays": 30,
    "FutureDays": 365,
    "DeleteRemovedEvents": true,
    "DryRun": false,
    "StateDatabasePath": "state/sync-state.db",
    "ImportedTitlePrefix": "(G)"
  },
  "Logging": {
    "Directory": "logs",
    "MinimumLevel": "Information",
    "RetentionDays": 30
  },
  "Http": {
    "TimeoutSeconds": 60
  }
}
